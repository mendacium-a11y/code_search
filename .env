# Ollama Configuration
OLLAMA_BASE_URL="http://localhost:11434/v1"
LLM_MODEL="qwen2.5-coder:7b" # Can be changed to qwen2.5-coder:3b if VRAM is too tight

# Embedding & Search Configuration
# all-MiniLM-L6-v2 is an efficient, general-purpose sentence transformer
# ms-marco-MiniLM-L-6-v2 is a cross-encoder specifically trained for passage re-ranking
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"
CROSS_ENCODER_MODEL_NAME="cross-encoder/ms-marco-MiniLM-L-6-v2"

# Ingestion Settings
INGEST_LIMIT=500
CHROMA_DB_PATH="./chroma_db"
COLLECTION_NAME="code_search"
